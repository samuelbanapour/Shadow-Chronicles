# Copy this file to `keystore.properties` and fill in your real values.
# The real keystore.properties and the .keystore file are gitignored — NEVER commit them.
#
# storeFile is resolved relative to the android/ folder. Place your release keystore
# at the repo's android-app/ root (e.g. android-app/android-original.keystore) or adjust the path.
storeFile=../android-original.keystore
storePassword=YOUR_KEYSTORE_PASSWORD
keyAlias=android
keyPassword=YOUR_KEY_PASSWORD
